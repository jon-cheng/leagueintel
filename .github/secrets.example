# .github/secrets.example
# GitHub Actions secrets reference
# DO NOT commit actual values — this is a template only
# Actual values stored in: github.com/jon-cheng/leagueintel/settings/secrets/actions

AWS_ACCESS_KEY_ID_REFRESH=        # leagueintel-refresh IAM user access key
AWS_SECRET_ACCESS_KEY_REFRESH=    # leagueintel-refresh IAM user secret
LEAGUE_ID=                        # ESPN league ID
ESPN_S2=                          # ESPN_S2 cookie (from browser devtools)
SWID=                             # SWID cookie (from browser devtools)