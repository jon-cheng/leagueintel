# .streamlit/secrets.toml.example
# Template for Streamlit Community Cloud secrets.
# DO NOT commit actual values — copy this to .streamlit/secrets.toml locally
# (gitignored), or paste into the app's Settings > Secrets on Streamlit Cloud.

LEAGUE_ID =                    # ESPN league ID
SWID =                         # SWID cookie (from browser devtools)
ESPN_S2 =                      # ESPN_S2 cookie (from browser devtools)
AWS_ACCESS_KEY_ID =            # S3 read access for DB download
AWS_SECRET_ACCESS_KEY =        # S3 read access for DB download
AWS_DEFAULT_REGION =           # e.g. us-west-2
S3_BUCKET =                    # e.g. leagueintel-data
S3_KEY =                       # e.g. leagueintel.db
DB_PATH =                      # e.g. /tmp/leagueintel.db on Streamlit Cloud
CHATBOT_DAILY_TOKEN_LIMIT =    # daily token budget across all users
LEAGUE_PASSWORD =              # password gate for league access
ANTHROPIC_API_KEY =            # Claude API key for chatbot
