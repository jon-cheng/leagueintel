LEAGUE_ID=your_league_id_here
ESPN_S2=your_espn_s2_cookie_here
SWID={your_swid_cookie_here}

# required for local dev
LEAGUE_PASSWORD=your_league_password_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# optional — have working defaults, only matter for cloud deployment
DB_PATH=
S3_BUCKET=
S3_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
CHATBOT_DAILY_TOKEN_LIMIT=

# Turso (hosted SQLite) — leagueintel-ops DB for chatbot usage tracking
TURSO_OPS_URL=libsql://leagueintel-ops-xxx.aws-us-west-2.turso.io
TURSO_OPS_TOKEN=your-token-here